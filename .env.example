# =====================================================================
# VoiceStream — exemplo de variáveis de ambiente
# Em produção, todos os segredos ficam como Docker secrets, montados em
# /run/secrets/* e exportados pelo docker/entrypoint.sh antes do start.
# =====================================================================

# ---------- Core ----------
# Postgres (em prod usar DNS interno do swarm, ex.: postgres://.../voicestream)
DATABASE_URL="postgresql://voicestream:voicestream@localhost:5432/voicestream?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="VoiceStream"

# ---------- Auth (Fase 1) ----------
# better-auth — gerar com: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-min-32-bytes"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Google (Fase 1.A)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Email transacional (Fase 1.C) ----------
RESEND_API_KEY=""
RESEND_FROM="VoiceStream <no-reply@voicestream.com.br>"

# ---------- Storage SeaweedFS — S3 compatível (Fase 2.A) ----------
S3_ENDPOINT="http://localhost:8333"
# Public S3 endpoint used to mint presigned URLs the browser will hit.
# Dev: leave empty (falls back to S3_ENDPOINT). Prod: must be HTTPS.
S3_PUBLIC_ENDPOINT=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="voicestream-recordings"
S3_FORCE_PATH_STYLE="true"

# ---------- Filas / Cache — Dragonfly (Redis-compat) (Fase 2.B / 4.C) ----------
REDIS_URL="redis://localhost:6379"

# ---------- Transcrição (Fase 2.B) ----------
DEEPGRAM_API_KEY=""

# ---------- LLM (Fase 2.B) ----------
ANTHROPIC_API_KEY=""

# ---------- Stripe (Fase 3) ----------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""
STRIPE_PRICE_ADDON_200=""

# ---------- Criptografia em repouso (Fase 4.B) ----------
# Master key AES-GCM, 32 bytes em base64
ENCRYPTION_KEY=""

# ---------- Observabilidade (Fase 4.C) ----------
SENTRY_DSN=""
LOG_LEVEL="info"

# ---------- Cron jobs (Fase 12.K) ----------
# Segredo para autorizar requisições cron (Bearer token); gerar com: node -e "require('crypto').randomBytes(24).toString('hex')"
CRON_SECRET="change-me-min-16-chars"
