{
  "name": "vibecoding-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "E2E_DETERMINISTIC_AUTH=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify:docs-product": "bash scripts/verify-docs.sh",
    "verify:docs-integrity": "bash scripts/verify-docs-integrity.sh",
    "verify:framework": "bash scripts/verify-framework.sh",
    "verify:commands": "node scripts/verify-command-skills.mjs",
    "manifest": "node scripts/generate-framework-manifest.mjs",
    "check:metadata": "node scripts/check-metadata-contract.mjs",
    "sitemap": "npx tsx scripts/generate-sitemap.ts",
    "lhci": "npx --yes @lhci/cli autorun 2>/dev/null || true",
    "db:seed": "prisma db seed",
    "db:demo:wipe": "tsx prisma/wipe-demo.ts",
    "verify": "bash scripts/verify-docs.sh && bash scripts/verify-framework.sh && bash scripts/verify-docs-integrity.sh && node scripts/verify-command-skills.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/adapter-pg-worker": "^6.9.0",
    "@prisma/client": "^7.7.0",
    "@prisma/pg-worker": "^6.9.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.2",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.2",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "prisma": "^7.7.0",
    "react-email": "^6.0.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
