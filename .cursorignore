# ─── Dependências ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
.next/
out/
build/
storybook-static/

# ─── Variáveis de ambiente e secrets ─────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
secrets/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Cache e temporários ─────────────────────────────────────────────────────
.turbo/
.cache/
*.tsbuildinfo
.eslintcache
.swc/

# ─── Cobertura de testes ─────────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ─── Git ──────────────────────────────────────────────────────────────────────
.git/

# ─── Lock files (grandes, desnecessários para contexto) ──────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Assets binários (não contribuem para contexto de código) ────────────────
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.woff
*.woff2
*.ttf
*.otf
*.eot
*.mp4
*.mp3
*.pdf

# ─── Arquivos de sistema ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Migrations de banco (históricas, raramente úteis no contexto ativo) ─────
# Descomente se Prisma/Drizzle gerar muitas migrations
# prisma/migrations/
# drizzle/migrations/

# ─── NOTA: O que NÃO ignorar ─────────────────────────────────────────────────
# .cursor/          → skills, agents, rules (contexto essencial do agente)
# docs/             → documentação por fase (fonte de verdade)
# src/ / app/       → código da aplicação
# scripts/          → verify-docs.sh e automações
