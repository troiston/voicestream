generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// better-auth core models
// ============================================================

model User {
  id               String      @id @default(cuid())
  name             String
  email            String      @unique
  emailVerified    Boolean     @default(false)
  image            String?
  bio              String?
  phone            String?
  isDemo           Boolean     @default(false)
  twoFactorEnabled Boolean?    @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?
  onboardingCompletedAt DateTime?

  preferences      Json?

  sessions      Session[]
  accounts      Account[]
  twofactors    TwoFactor[]
  subscriptions Subscription[]
  usage         Usage[]

  ownedSpaces      Space[]        @relation("SpaceOwner")
  spaceMemberships SpaceMember[]
  recordings       Recording[]
  createdTasks     Task[]         @relation("TaskCreator")
  assignedTasks    Task[]         @relation("TaskAssignee")
  auditLogs        AuditLog[]
  spaceInvitesSent SpaceInvite[]
  integrations     Integration[]
  comments         Comment[]      @relation("CommentAuthor")

  @@index([isDemo])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  verified    Boolean? @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

// ============================================================
// Stripe / domínio
// ============================================================

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  stripeCustomerId     String   @unique
  stripePriceId        String
  stripeSubscriptionId String   @unique
  status               String
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Usage {
  id        String   @id @default(cuid())
  userId    String
  type      String
  quantity  Int
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

// ============================================================
// VoiceStream domain
// ============================================================

enum SpaceKind {
  trabalho
  familia
  saude
  financas
  pessoal
  outros
}

enum SpaceMemberRole {
  owner
  admin
  membro
  convidado
}

enum SpaceMemberStatus {
  pending
  active
  revoked
}

enum RecordingStatus {
  uploaded
  processing
  transcribed
  summarized
  failed
}

enum TranscriptionProvider {
  deepgram
  whisper
  other
}

enum TaskStatus {
  pendente
  em_curso
  concluida
  cancelada
}

enum TaskPriority {
  baixa
  media
  alta
}

model Space {
  id          String    @id @default(cuid())
  ownerId     String
  name        String
  description String?
  kind        SpaceKind
  color       String?
  icon        String?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User          @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     SpaceMember[]
  invites     SpaceInvite[]
  recordings  Recording[]
  tasks       Task[]
  taskColumns TaskColumn[]
  labels      Label[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([kind])
  @@map("space")
}

model TaskColumn {
  id        String   @id @default(cuid())
  spaceId   String
  name      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([spaceId])
  @@unique([spaceId, name])
  @@map("task_column")
}

model SpaceMember {
  id        String            @id @default(cuid())
  spaceId   String
  userId    String
  role      SpaceMemberRole
  invitedAt DateTime          @default(now())
  joinedAt  DateTime?
  status    SpaceMemberStatus @default(pending)

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([userId])
  @@index([spaceId, status])
  @@map("space_member")
}

model SpaceInvite {
  id              String          @id @default(cuid())
  spaceId         String
  invitedByUserId String
  email           String
  role            SpaceMemberRole
  token           String          @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime        @default(now())

  space     Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  invitedBy User  @relation(fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([email])
  @@map("space_invite")
}

model Recording {
  id           String          @id @default(cuid())
  spaceId      String
  userId       String
  title        String?
  storageKey   String          @unique
  durationSec  Int
  mimeType     String          @default("audio/webm")
  language     String          @default("pt-BR")
  status       RecordingStatus @default(uploaded)
  errorMessage String?
  capturedAt   DateTime
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  encryptionMeta Json?

  space         Space          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcription Transcription?
  summary       Summary?
  tasks         Task[]

  @@index([spaceId, capturedAt(sort: Desc)])
  @@index([userId])
  @@index([status])
  @@map("recording")
}

model Transcription {
  id           String                @id @default(cuid())
  recordingId  String                @unique
  provider     TranscriptionProvider
  language     String
  text         String                @db.Text
  confidence   Float?
  rawJson      Json?
  encrypted    Boolean               @default(false)
  createdAt    DateTime              @default(now())

  recording Recording              @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  segments  TranscriptionSegment[]
  summary   Summary?

  @@index([recordingId])
  @@map("transcription")
}

model TranscriptionSegment {
  id              String  @id @default(cuid())
  transcriptionId String
  speaker         String?
  startMs         Int
  endMs           Int
  text            String  @db.Text
  confidence      Float?
  encrypted       Boolean @default(false)

  transcription Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)

  @@index([transcriptionId, startMs])
  @@map("transcription_segment")
}

model Summary {
  id              String   @id @default(cuid())
  recordingId     String   @unique
  transcriptionId String   @unique
  title           String?
  abstract        String   @db.Text
  decisions       String[]
  nextSteps       String[]
  llmModel        String   @default("claude-sonnet-4-6")
  tokensInput     Int?
  tokensOutput    Int?
  createdAt       DateTime @default(now())

  recording     Recording     @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  transcription Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)

  @@index([recordingId])
  @@map("summary")
}

model Task {
  id              String       @id @default(cuid())
  spaceId         String
  recordingId     String?
  creatorUserId   String
  assigneeUserId  String?
  columnId        String?
  title           String
  description     String       @db.Text
  status          TaskStatus   @default(pendente)
  priority        TaskPriority @default(media)
  order           Int          @default(0)
  dueAt           DateTime?
  completedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  space       Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  recording   Recording?  @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  creator     User        @relation("TaskCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  assignee    User?       @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  column      TaskColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  labels      TaskLabel[]
  checklists  Checklist[]
  comments    Comment[]
  attachments Attachment[]

  @@index([spaceId, status])
  @@index([assigneeUserId, status])
  @@index([recordingId])
  @@index([columnId])
  @@map("task")
}

model Integration {
  id           String    @id @default(cuid())
  userId       String
  provider     String    // "google_calendar" | "notion" | "slack" | "zapier" | "hubspot" | "microsoft"
  status       String    // "disconnected" | "connected" | "error"
  accessToken  String?   // criptografado (AES-GCM); null se disconnected
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json?
  connectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("integration")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_log")
}

// ============================================================
// Task Trello-like features
// ============================================================

model Label {
  id      String      @id @default(cuid())
  spaceId String
  name    String
  color   String

  space  Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks  TaskLabel[]

  @@unique([spaceId, name])
  @@index([spaceId])
  @@map("label")
}

model TaskLabel {
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_label")
}

model Checklist {
  id     String @id @default(cuid())
  taskId String
  title  String
  order  Int    @default(0)

  task  Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([taskId])
  @@map("checklist")
}

model ChecklistItem {
  id          String  @id @default(cuid())
  checklistId String
  text        String
  done        Boolean @default(false)
  order       Int     @default(0)

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("checklist_item")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("comment")
}

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  s3Key        String
  filename     String
  size         Int
  mimeType     String
  uploadedAt   DateTime @default(now())
  uploadedById String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("attachment")
}
